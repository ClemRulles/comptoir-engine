# engine/.env.example — copie ce fichier en engine/.env et remplis les clés.
# Le moteur tourne SANS clé (Yahoo + OpenInsider suffisent à un gate exploitable) ;
# les clés ci-dessous enrichissent les signaux. Ne committe JAMAIS engine/.env.
#
# Chargement : `node --env-file=engine/.env engine/signals.js` (Node 20+),
# ou exporte les variables dans ton shell, ou définis-les en secrets GitHub Actions.

# Financial Modeling Prep — F-Score Piotroski + qualité des earnings (accruals).
# Clé gratuite (~250 req/jour) : https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# FRED (Fed de St. Louis) — régime macro + proxy peur/avidité (VIX, spreads HY).
# Clé gratuite : https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# Alpha Vantage — EPS surprise + croissance du CA YoY (free tier 25 req/jour).
# Clé gratuite : https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# Finnhub — optionnel (repli fondamentaux). Clé gratuite : https://finnhub.io
FINNHUB_API_KEY=
